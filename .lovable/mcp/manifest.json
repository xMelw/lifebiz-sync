{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ndymqfvzlmdqelxpxhqk.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "casa-negocio-mcp",
      "version": "0.1.0",
      "title": "Casa & Negócio"
    },
    "tools": [
      {
        "name": "list_orders",
        "title": "Listar encomendas",
        "description": "Lista as encomendas mais recentes do workspace do utilizador (modo Negócio).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Número máximo de encomendas a devolver (por defeito 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "status": {
              "description": "Filtrar por status (ex.: rascunho, pendente_aprovacao, confirmada).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_customers",
        "title": "Listar clientes",
        "description": "Lista clientes do workspace, opcionalmente filtrados por nome ou email.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "search": {
              "description": "Texto para filtrar por nome ou email.",
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_products",
        "title": "Listar produtos (Negócio)",
        "description": "Lista produtos do stock do modo Negócio, com preço e quantidade em stock.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "search": {
              "description": "Filtro por nome do produto.",
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_home_stock",
        "title": "Listar stock de Casa",
        "description": "Lista os itens em stock no modo Casa (despensa/casa), com quantidade e validade.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "low_only": {
              "description": "Apenas itens abaixo do mínimo.",
              "type": "boolean"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_order",
        "title": "Criar encomenda (rascunho)",
        "description": "Cria uma nova encomenda em rascunho no modo Negócio, associada opcionalmente a um cliente.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "customer_id": {
              "description": "ID do cliente.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "notes": {
              "description": "Notas internas da encomenda.",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
